    <string name="sol_mango_mildew">15 ದಿನಗಳ ಅಂತರದಲ್ಲಿ 2 ಗ್ರಾಂ/ಲೀಟರ್ ನೀರಿನಲ್ಲಿ ಕರಗುವ ಗಂಧಕವನ್ನು ಸಿಂಪಡಿಸಿ।</string>
    <string name="sol_mango_anthracnose">ಕಾರ್ಬೆಂಡಾಜಿಮ್ 1 ಗ್ರಾಂ/ಲೀಟರ್ ಅಥವಾ ಕಾಪರ್ ಆಕ್ಸಿಕ್ಲೋರೈಡ್ 3 ಗ್ರಾಂ/ಲೀಟರ್ ಸಿಂಪಡಿಸಿ।</string>
    <string name="sol_wheat_rust">ರೋಗ ನಿರೋಧಕ ತಳಿಗಳನ್ನು (HD 2967) ಬಳಸಿ ಅಥವಾ ಪ್ರೊಪಿಕೊನಜೋಲ್ ಸಿಂಪಡಿಸಿ।</string>
    <string name="sol_wheat_smut">ವಿಟಾವ್ಯಾಕ್ಸ್ (2 ಗ್ರಾಂ/ಕೆಜಿ ಬೀಜ) ನೊಂದಿಗೆ ಬೀಜೋಪಚಾರ ಮಾಡಿ।</string>
    <string name="sol_rice_blast">ಟ್ರೈಸೈಕ್ಲಾಜೋಲ್ 0.6 ಗ್ರಾಂ/ಲೀಟರ್ ಅಥವಾ ಕಾರ್ಬೆಂಡಾಜಿಮ್ 1 ಗ್ರಾಂ/ಲೀಟರ್ ಸಿಂಪಡಿಸಿ।</string>
    <string name="sol_rice_bph">ಪ್ರತಿ 2 ಮೀಟರ್ ಸಾಲುಗಳ ನಡುವೆ 30 ಸೆಂ.ಮೀ ಖಾಲಿ ಜಾಗವನ್ನು ಕಾಪಾಡಿಕೊಳ್ಳಿ।</string>
    <string name="sol_cotton_bollworm">ಲಿಂಗಾಕರ್ಷಕ ಬಲೆಗಳನ್ನು ಬಳಸಿ ಮತ್ತು ಸ್ಪಿನೋಸ್ಯಾಡ್ 45 ಎಸ್‌ಸಿ ಸಿಂಪಡಿಸಿ।</string>
    <string name="sol_cotton_aphids">ಮೀಥೈಲ್ ಡೆಮೆಟಾನ್ 2 ಮಿಲಿ/ಲೀಟರ್ ಸಿಂಪಡಿಸಿ।</string>
