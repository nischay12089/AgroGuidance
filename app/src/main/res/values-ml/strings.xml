    <!-- Solutions -->
    <string name="sol_mango_mildew">15 ദിവസത്തെ ഇടവേളയിൽ 2 ഗ്രാം/ലിറ്റർ എന്ന തോതിൽ നനയ്ക്കാവുന്ന സൾഫർ തളിക്കുക.</string>
    <string name="sol_mango_anthracnose">കാർബൻഡാസിം 1 ഗ്രാം/ലിറ്റർ അല്ലെങ്കിൽ കോപ്പർ ഓക്സിക്ലോറൈഡ് 3 ഗ്രാം/ലിറ്റർ തളിക്കുക.</string>
    <string name="sol_wheat_rust">പ്രതിരോധശേഷിയുള്ള ഇനങ്ങൾ (HD 2967) ഉപയോഗിക്കുക അല്ലെങ്കിൽ പ്രൊപ്പികോണസോൾ തളിക്കുക.</string>
    <string name="sol_wheat_smut">വിറ്റാവാക്സ് (2 ഗ്രാം/കിലോ വിത്ത്) ഉപയോഗിച്ച് വിത്ത് ചികിത്സിക്കുക.</string>
    <string name="sol_rice_blast">ട്രൈസൈക്ലസോൾ 0.6 ഗ്രാം/ലിറ്റർ അല്ലെങ്കിൽ കാർബൻഡാസിം 1 ഗ്രാം/ലിറ്റർ തളിക്കുക.</string>
    <string name="sol_rice_bph">ഓരോ 2 മീറ്റർ വരികൾക്കിടയിലും 30 സെന്റീമീറ്റർ വ്യക്തമായ ഇടം നിലനിർത്തുക.</string>
    <string name="sol_cotton_bollworm">ഫെറോമോൺ കെണികൾ ഉപയോഗിക്കുക, സ്പിനോസാഡ് 45 എസ്‌സി തളിക്കുക.</string>
    <string name="sol_cotton_aphids">മീഥൈൽ ഡെമെറ്റൺ 2 മില്ലി/ലിറ്റർ തളിക്കുക.</string>
</resources>