    <!-- Solutions -->
    <string name="sol_mango_mildew">15 ਦਿਨਾਂ ਦੇ ਵਕਫੇ ਤੇ 2 ਗ੍ਰਾਮ/ਲਿਟਰ ਘੁਲਣਸ਼ੀਲ ਗੰਧਕ ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
    <string name="sol_mango_anthracnose">ਕਾਰਬੈਂਡਾਜ਼ਿਮ 1 ਗ੍ਰਾਮ/ਲਿਟਰ ਜਾਂ ਕਾਪਰ ਆਕਸੀਕਲੋਰਾਈਡ 3 ਗ੍ਰਾਮ/ਲਿਟਰ ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
    <string name="sol_wheat_rust">ਰੋਧਕ ਕਿਸਮਾਂ (HD 2967) ਦੀ ਵਰਤੋਂ ਕਰੋ ਜਾਂ ਪ੍ਰੋਪੀਕੋਨਾਜ਼ੋਲ ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
    <string name="sol_wheat_smut">ਵੀਟਾਵੈਕਸ (2 ਗ੍ਰਾਮ/ਕਿਲੋ ਬੀਜ) ਨਾਲ ਬੀਜ ਦੀ ਸੋਧ ਕਰੋ।</string>
    <string name="sol_rice_blast">ਟ੍ਰਾਈਸਾਈਕਲਾਜ਼ੋਲ 0.6 ਗ੍ਰਾਮ/ਲਿਟਰ ਜਾਂ ਕਾਰਬੈਂਡਾਜ਼ਿਮ 1 ਗ੍ਰਾਮ/ਲਿਟਰ ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
    <string name="sol_rice_bph">ਹਰ 2 ਮੀਟਰ ਕਤਾਰਾਂ ਵਿਚਕਾਰ 30 ਸੈਂਟੀਮੀਟਰ ਖਾਲੀ ਜਗ੍ਹਾ ਰੱਖੋ।</string>
    <string name="sol_cotton_bollworm">ਫੇਰੋਮੋਨ ਟ੍ਰੈਪਸ ਦੀ ਵਰਤੋਂ ਕਰੋ ਅਤੇ ਸਪਿਨੋਸੈਡ 45 SC ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
    <string name="sol_cotton_aphids">ਮਿਥਾਈਲ ਡੈਮੇਟਨ 2 ਮਿਲੀ/ਲਿਟਰ ਦਾ ਛਿੜਕਾਅ ਕਰੋ।</string>
