    <!-- Solutions -->
    <string name="sol_mango_mildew">Spray wettable sulphur 2g/lit at 15 days interval.</string>
    <string name="sol_mango_anthracnose">Spray Carbendazim 1g/lit or Copper Oxychloride 3g/lit.</string>
    <string name="sol_wheat_rust">Use resistant varieties (HD 2967) or spray Propiconazole.</string>
    <string name="sol_wheat_smut">Seed treatment with Vitavax (2g/kg seed).</string>
    <string name="sol_rice_blast">Spray Tricyclazole 0.6g/lit or Carbendazim 1g/lit.</string>
    <string name="sol_rice_bph">Maintain 30cm clear space between every 2m rows.</string>
    <string name="sol_cotton_bollworm">Use pheromone traps and spray Spinosad 45 SC.</string>
    <string name="sol_cotton_aphids">Spray Methyl Demeton 2ml/lit.</string>
