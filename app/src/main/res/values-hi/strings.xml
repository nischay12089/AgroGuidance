    <!-- Solutions -->
    <string name="sol_mango_mildew">15 दिनों के अंतराल पर 2 ग्राम/लीटर घुलनशील गंधक (सल्फर) का छिड़काव करें।</string>
    <string name="sol_mango_anthracnose">कार्बेन्डाजिम 1 ग्राम/लीटर या कॉपर ऑक्सीक्लोराइड 3 ग्राम/लीटर का छिड़काव करें।</string>
    <string name="sol_wheat_rust">प्रतिरोधी किस्मों (HD 2967) का उपयोग करें या प्रोपिकोनाज़ोल का छिड़काव करें।</string>
    <string name="sol_wheat_smut">विटावैक्स (2 ग्राम/किग्रा बीज) के साथ बीज उपचार करें।</string>
    <string name="sol_rice_blast">ट्राइसाइक्लाज़ोल 0.6 ग्राम/लीटर या कार्बेन्डाजिम 1 ग्राम/लीटर का छिड़काव करें।</string>
    <string name="sol_rice_bph">प्रत्येक 2 मीटर की कतारों के बीच 30 सेमी खाली स्थान रखें।</string>
    <string name="sol_cotton_bollworm">फेरोमोन ट्रैप का उपयोग करें और स्पिनोसैड 45 SC का छिड़काव करें।</string>
    <string name="sol_cotton_aphids">मिथाइल डेमेटोन 2 मिली/लीटर का छिड़काव करें।</string>
