    <!-- Solutions -->
    <string name="sol_mango_mildew">15 రోజుల వ్యవధిలో 2 గ్రా/లీటరు చొప్పున నీటిలో కరిగే గంధకాన్ని పిచికారీ చేయండి।</string>
    <string name="sol_mango_anthracnose">కార్బెండజిమ్ 1 గ్రా/లీటరు లేదా కాపర్ ఆక్సిక్లోరైడ్ 3 గ్రా/లీటరు పిచికారీ చేయండి।</string>
    <string name="sol_wheat_rust">నిరోధక రకాలను (HD 2967) ఉపయోగించండి లేదా ప్రోపికోనజోల్ పిచికారీ చేయండి।</string>
    <string name="sol_wheat_smut">విటావాక్స్‌తో (2 గ్రా/కేజీ విత్తనం) విత్తన శుద్ధి చేయండి।</string>
    <string name="sol_rice_blast">ట్రైసైక్లాజోల్ 0.6 గ్రా/లీటరు లేదా కార్బెండజిమ్ 1 గ్రా/లీటరు పిచికారీ చేయండి।</string>
    <string name="sol_rice_bph">ప్రతి 2 మీటర్ల వరుసల మధ్య 30 సెం.మీ ఖాళీ స్థలాన్ని ఉంచండి।</string>
    <string name="sol_cotton_bollworm">ఫెరోమోన్ ట్రాప్స్ ఉపయోగించండి మరియు స్పినోసాడ్ 45 ఎస్సీ పిచికారీ చేయండి।</string>
    <string name="sol_cotton_aphids">మిథైల్ డెమెటాన్ 2 మి.లీ/లీటరు పిచికారీ చేయండి।</string>
