    <!-- Solutions -->
    <string name="sol_mango_mildew">15 நாட்கள் இடைவெளியில் 2 கிராம்/லிட்டர் நனைக்கும் கந்தகத்தைத் தெளிக்கவும்.</string>
    <string name="sol_mango_anthracnose">கார்பென்டாசிம் 1 கிராம்/லிட்டர் அல்லது காப்பர் ஆக்ஸிகுளோரைடு 3 கிராம்/லிட்டர் தெளிக்கவும்.</string>
    <string name="sol_wheat_rust">எதிர்ப்புத் திறன் கொண்ட ரகங்களை (HD 2967) பயன்படுத்தவும் அல்லது புரோப்பிகோனசோலைத் தெளிக்கவும்.</string>
    <string name="sol_wheat_smut">விட்டாவாக்ஸ் (2 கிராம்/கிலோ விதை) கொண்டு விதை நேர்த்தி செய்யவும்.</string>
    <string name="sol_rice_blast">ட்ரைசைக்ளசோல் 0.6 கிராம்/லிட்டர் அல்லது கார்பென்டாசிம் 1 கிராம்/லிட்டர் தெளிக்கவும்.</string>
    <string name="sol_rice_bph">ஒவ்வொரு 2 மீட்டர் வரிசைகளுக்கு இடையிலும் 30 செ.மீ இடைவெளி விடவும்.</string>
    <string name="sol_cotton_bollworm">பெரோமோன் பொறிகளைப் பயன்படுத்தவும் மற்றும் ஸ்பினோசாட் 45 எஸ்சி தெளிக்கவும்.</string>
    <string name="sol_cotton_aphids">மெத்தில் டெமெட்டான் 2 மி.லி/லிட்டர் தெளிக்கவும்.</string>
</resources>