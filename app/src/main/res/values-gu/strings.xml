    <!-- Solutions -->
    <string name="sol_mango_mildew">15 દિવસના અંતરે 2 ગ્રામ/લિટર પાણીમાં દ્રાવ્ય ગંધકનો છંટકાવ કરો.</string>
    <string name="sol_mango_anthracnose">કાર્બેન્ડાઝીમ 1 ગ્રામ/લિટર અથવા કોપર ઓક્સિક્લોરાઇડ 3 ગ્રામ/લિટરનો છંટકાવ કરો.</string>
    <string name="sol_wheat_rust">પ્રતિરોધક જાતો (HD 2967) નો ઉપયોગ કરો અથવા પ્રોપિકોનાઝોલનો છંટકાવ કરો.</string>
    <string name="sol_wheat_smut">વિટાવાક્સ (2 ગ્રામ/કિલો બીજ) સાથે બીજ માવજત કરો.</string>
    <string name="sol_rice_blast">ટ્રાયસાઇક્લાઝોલ 0.6 ગ્રામ/લિટર અથવા કાર્બેન્ડાઝીમ 1 ગ્રામ/લિટરનો છંટકાવ કરો.</string>
    <string name="sol_rice_bph">દરેક 2 મીટરની હાર વચ્ચે 30 સેમી ખાલી જગ્યા રાખો.</string>
    <string name="sol_cotton_bollworm">ફેરોમોન ટ્રેપ્સનો ઉપયોગ કરો અને સ્પીનોસેડ 45 SC નો છંટકાવ કરો.</string>
    <string name="sol_cotton_aphids">મિથાઈલ ડેમેટોન 2 મિલી/લિટરનો છંટકાવ કરો.</string>
